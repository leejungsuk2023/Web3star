VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# web = 소개·가입만(GitHub Pages). app = 마이닝 본앱(Capacitor). 로컬 dev는 .env.development(app) 사용.
# VITE_DEPLOY_TARGET=web

# 에뮬레이터 Google 로그인용 (GitHub Pages 배포 후 Supabase Redirect URL에 아래 주소 추가)
VITE_OAUTH_CALLBACK_URL=https://leejungsuk2023.github.io/Web3star/oauth-callback.html

# Android 네이티브 Google 로그인(ID Token)용 Web Client ID
# 예: 1234567890-xxxxxxxxxxxxxxxxxxxxxxxxxxxx.apps.googleusercontent.com
VITE_GOOGLE_WEB_CLIENT_ID=
